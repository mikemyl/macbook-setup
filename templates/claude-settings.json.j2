{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(date:*)",
      "Bash(echo:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(wc:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(sort:*)",
      "Bash(grep:*)",
      "Bash(tr:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git tag:*)"
    ]
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "medium",
  "teammateMode": "tmux",
  "enabledPlugins": {
{% for plugin in claude_plugins %}
    "{{ plugin }}": true{{ "," if not loop.last else "" }}
{% endfor %}
  }{% if claude_extra_marketplaces %},
  "extraKnownMarketplaces": {
{% for name, url in claude_extra_marketplaces.items() %}
    "{{ name }}": {
      "source": {
        "source": "git",
        "url": "{{ url }}"
      }
    }{{ "," if not loop.last else "" }}
{% endfor %}
  },
{% endif %}
  "statusLine": {
    "type": "command",
    "command": "node ~/.claude/hooks/vd-statusline.js"
  }
}
